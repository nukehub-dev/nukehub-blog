---
import { format } from "date-fns";
import { getEntry, getCollection, render } from "astro:content";
import { cn } from "@lib/utils";
import BaseLayout from "./BaseLayout.astro";
import { Badge } from "@components/ui/Badge";
import { CoverImage } from "@components/blog/CoverImage";
import { AuthorBio } from "@components/blog/AuthorBio";
import { PostCard } from "@components/blog/PostCard";
import PostContent from "@components/blog/PostContent.astro";
import { ReadingProgress } from "@components/blog/ReadingProgress";
import { TableOfContents } from "@components/blog/TableOfContents";
import { PostShareCite } from "@components/blog/PostShareCite";
import { getCategoryLabel } from "@lib/categories";
import { getReadingTime, getRelatedPosts, type Post } from "@lib/posts";
import { resolvePostImage } from "@lib/postImages";
import { resolvePostImagePath } from "@lib/postImagePath";
import type { Author } from "@lib/posts";
import { MDXComponents } from "@components/mdx/MDXComponents";
import { References } from "@components/mdx/References";
import { SITE } from "@data/site";
import sharp from "sharp";

interface Props {
  post: Post;
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const {
  title,
  description,
  publishedDate,
  updatedDate,
  category,
  author: authorId,
  coAuthors: coAuthorIds,
  tags,
  coverImage,
  coverImageFit,
  coverImageTransparent,
  canonicalUrl,
  references,
  citable,
} = post.data;

const fit = coverImageFit ?? "cover";
const isContain = fit === "contain";
const coverImageSrc = resolvePostImage(coverImage, post.id);

// Read the cover image dimensions at build time so contained covers can use the
// image's natural aspect ratio instead of being forced into a fixed ratio.
let coverAspectRatio: string | undefined;
if (coverImageSrc) {
  const filePath = resolvePostImagePath(coverImage, post);
  try {
    const metadata = await sharp(filePath).metadata();
    if (metadata.width && metadata.height) {
      coverAspectRatio = `${metadata.width} / ${metadata.height}`;
    }
  } catch {
    coverAspectRatio = undefined;
  }
}

const authorEntries = await Promise.all(
  [authorId, ...(coAuthorIds ?? [])]
    .filter(Boolean)
    .map((id) => getEntry("authors", id)),
);
const authors = authorEntries.filter((a): a is Author => Boolean(a));
const authorsWithDetails = authors.filter((a) => {
  const { avatar, bio, role, organization, location, email, url, links } =
    a.data;
  return (
    avatar ||
    bio ||
    role ||
    organization ||
    location ||
    email ||
    url ||
    (links && Object.keys(links).length > 0)
  );
});
const allPosts = await getCollection("posts");
const relatedPosts = getRelatedPosts(post, allPosts, 3);
const readingTime = getReadingTime(post.body ?? "");

const permalink = `/posts/${post.id}`;
const pageImage = coverImageSrc || SITE.ogImage;

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description,
  url: `${SITE.url}${permalink}`,
  image: `${SITE.url}${pageImage}`,
  datePublished: publishedDate.toISOString(),
  dateModified: updatedDate?.toISOString() ?? publishedDate.toISOString(),
  author: authors.map((a) => ({
    "@type": "Person",
    name: a.data.name,
    url: `${SITE.url}/authors/${a.id}`,
  })),
  keywords: tags.join(", "),
};
---

<BaseLayout
  title={title}
  description={description}
  permalink={permalink}
  image={pageImage}
  jsonLd={articleJsonLd}
>
  <ReadingProgress client:idle />

  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="flex flex-col gap-12 lg:flex-row lg:justify-center">
      <article id="article-content" class="w-full max-w-3xl">
        {
          post.data.draft && (
            <div class="mb-6 rounded-lg border border-primary/30 bg-primary/10 px-4 py-3 text-sm text-primary">
              <span class="font-semibold">Draft</span> — visible in development,
              excluded from production builds.
            </div>
          )
        }

        <header class="space-y-6">
          <div class="flex flex-wrap items-center gap-2">
            <Badge variant="default">{getCategoryLabel(category)}</Badge>
            {tags.map((tag) => <Badge variant="ghost">{tag}</Badge>)}
          </div>

          <h1 class="text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">
            {title}
          </h1>

          <p class="text-lg text-muted-foreground">{description}</p>

          <div
            class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-muted-foreground"
          >
            <time datetime={publishedDate.toISOString()}>
              {format(publishedDate, "MMMM d, yyyy")}
            </time>
            {
              updatedDate && (
                <span>
                  Updated{" "}
                  <time datetime={updatedDate.toISOString()}>
                    {format(updatedDate, "MMMM d, yyyy")}
                  </time>
                </span>
              )
            }
            <span>{readingTime} min read</span>
            {
              canonicalUrl && (
                <a
                  href={canonicalUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-primary hover:underline"
                >
                  Originally published
                </a>
              )
            }
            <div class="sm:ml-auto">
              <PostShareCite
                client:load
                title={title}
                url={`${SITE.url}${permalink}`}
                authors={authors.map((a) => a.data.name)}
                date={format(publishedDate, "yyyy-MM-dd")}
                citationKey={post.id}
                citable={citable}
              />
            </div>
          </div>

          {
            authors.length > 0 && (
              <div class="flex flex-wrap items-center gap-3">
                {authors.map((a) => (
                  <a
                    href={`/authors/${a.id}`}
                    class="group inline-flex items-center gap-2 rounded-full border border-border/50 bg-card/50 px-3 py-1.5 text-sm transition-colors hover:border-primary/30 hover:bg-card"
                  >
                    {a.data.avatar ? (
                      <img
                        src={a.data.avatar}
                        alt={a.data.name}
                        class="h-6 w-6 rounded-full object-cover"
                        loading="lazy"
                      />
                    ) : (
                      <div class="flex h-6 w-6 items-center justify-center rounded-full bg-muted text-xs font-medium text-foreground">
                        {a.data.name.charAt(0).toUpperCase()}
                      </div>
                    )}
                    <span class="font-medium text-foreground group-hover:text-primary">
                      {a.data.name}
                    </span>
                  </a>
                ))}
              </div>
            )
          }

          {
            coverImageSrc && (
              <div
                class={cn(
                  "overflow-hidden rounded-xl border border-border/50",
                  isContain ? "flex items-center justify-center" : "bg-muted",
                  isContain && !coverImageTransparent && "bg-muted",
                )}
                style={
                  isContain && coverAspectRatio
                    ? { aspectRatio: coverAspectRatio }
                    : undefined
                }
              >
                <CoverImage
                  src={coverImageSrc}
                  alt={title}
                  fit={fit}
                  transparent={coverImageTransparent}
                  client:load
                />
              </div>
            )
          }
        </header>

        <div class="mt-10">
          <PostContent>
            <Content components={MDXComponents} />
          </PostContent>
        </div>

        {
          authorsWithDetails.length > 0 && (
            <div class="mt-12">
              <h2 class="mb-4 text-xl font-semibold tracking-tight">
                About the author{authorsWithDetails.length > 1 ? "s" : ""}
              </h2>
              <div class="flex flex-col gap-4">
                {authorsWithDetails.map((a) => (
                  <AuthorBio author={a} href={`/authors/${a.id}`} client:load />
                ))}
              </div>
            </div>
          )
        }

        {
          references.length > 0 && (
            <References references={references} client:visible />
          )
        }

        <div class="mt-12 border-t border-border/50 pt-6">
          <div class="flex flex-wrap items-center gap-x-4 gap-y-2">
            <a
              href={`${SITE.repo}/edit/main/${post.filePath ?? `src/content/posts/${post.id}/index.mdx`}`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 text-sm text-muted-foreground transition-colors hover:text-primary hover:underline"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path
                  d="M21.174 6.812a1 1 0 0 0-3.986-3.987L3.842 16.174a2 2 0 0 0-.5.83l-1.321 4.352a.5.5 0 0 0 .623.622l4.353-1.32a2 2 0 0 0 .83-.497z"
                ></path>
                <path d="m15 5 4 4"></path>
              </svg>
              Edit this page
            </a>
            <a
              href={`${permalink}/index.md`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 text-sm text-muted-foreground transition-colors hover:text-primary hover:underline"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path
                  d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"
                ></path>
                <path d="M14 2v4a2 2 0 0 0 2 2h4"></path>
                <path d="M10 9H8"></path>
                <path d="M16 13H8"></path>
                <path d="M16 17H8"></path>
              </svg>
              View in markdown
            </a>
          </div>
        </div>
      </article>

      <div class="hidden lg:block lg:w-56 lg:self-start lg:sticky lg:top-24">
        <TableOfContents headings={headings} client:load />
      </div>
    </div>
  </div>

  {
    relatedPosts.length > 0 && (
      <aside class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
        <h2 class="mb-8 text-2xl font-semibold tracking-tight">
          Related posts
        </h2>
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {relatedPosts.map((relatedPost) => (
            <PostCard post={relatedPost} client:load />
          ))}
        </div>
      </aside>
    )
  }

  <script is:inline>
    (function () {
      const blocks = document.querySelectorAll(
        "#article-content pre:has(code)",
      );
      blocks.forEach(function (pre) {
        const code = pre.querySelector("code");
        if (!code) return;

        const button = document.createElement("button");
        button.type = "button";
        button.className =
          "absolute right-2 top-2 inline-flex h-8 items-center gap-1 rounded-md bg-background/90 px-2 text-xs font-medium text-muted-foreground opacity-0 transition-opacity hover:text-foreground";
        button.setAttribute("aria-label", "Copy code");
        button.innerHTML =
          '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2"/></svg><span>Copy</span>';

        pre.style.position = "relative";
        pre.appendChild(button);

        pre.addEventListener("mouseenter", function () {
          button.classList.remove("opacity-0");
        });
        pre.addEventListener("mouseleave", function () {
          button.classList.add("opacity-0");
        });

        button.addEventListener("click", function () {
          const text = code.textContent || "";
          navigator.clipboard.writeText(text).then(function () {
            button.innerHTML =
              '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg><span>Copied</span>';
            setTimeout(function () {
              button.innerHTML =
                '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2"/></svg><span>Copy</span>';
            }, 2000);
          });
        });
      });
    })();
  </script>
</BaseLayout>
