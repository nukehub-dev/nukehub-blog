---
import { format } from "date-fns";
import { cn } from "@lib/utils";
import { Badge } from "@components/ui/Badge";
import { Image } from "@components/ui/Image";
import { getCategoryLabel } from "@lib/categories";
import { resolvePostImage } from "@lib/postImages";
import { resolvePostImagePath } from "@lib/postImagePath";
import type { Post } from "@lib/posts";
import sharp from "sharp";

interface Props {
  post: Post;
}

const { post } = Astro.props;
const {
  title,
  description,
  publishedDate,
  category,
  coverImage,
  coverImageFit,
  coverImageTransparent,
  tags,
} = post.data;

const fit = coverImageFit ?? "cover";
const isContain = fit === "contain";
const coverImageSrc = resolvePostImage(coverImage, post.id);

// Read the cover image dimensions at build time so contained covers can use the
// image's natural aspect ratio instead of being forced into 16:9.
let coverAspectRatio: string | undefined;
if (coverImageSrc) {
  const filePath = resolvePostImagePath(coverImage, post);
  try {
    const metadata = await sharp(filePath).metadata();
    if (metadata.width && metadata.height) {
      coverAspectRatio = `${metadata.width} / ${metadata.height}`;
    }
  } catch {
    coverAspectRatio = undefined;
  }
}
---

<section
  class="relative overflow-hidden rounded-2xl border border-border/50 bg-card shadow-sm"
>
  <div class="grid lg:grid-cols-2">
    {
      coverImageSrc && (
        <div
          class={cn(
            "relative self-center aspect-video overflow-hidden lg:aspect-auto",
            isContain
              ? "flex items-center justify-center p-2 sm:p-4"
              : "bg-muted",
            !coverImageTransparent && isContain && "bg-muted",
          )}
          style={
            isContain && coverAspectRatio
              ? { aspectRatio: coverAspectRatio }
              : undefined
          }
        >
          <Image
            src={coverImageSrc}
            alt={title}
            aspect="auto"
            rounded="md"
            fit={fit}
            transparent={coverImageTransparent}
            loading="eager"
            wrapperClassName="h-full w-full"
            client:load
          />
        </div>
      )
    }
    <div class="flex flex-col justify-center p-6 sm:p-10">
      <div class="flex flex-wrap items-center gap-2">
        <Badge variant="default">{getCategoryLabel(category)}</Badge>
        {tags.slice(0, 3).map((tag) => <Badge variant="ghost">{tag}</Badge>)}
      </div>
      <h1 class="mt-4 text-3xl font-bold tracking-tight sm:text-4xl">
        <a href={`/posts/${post.id}`} class="hover:underline">
          {title}
        </a>
      </h1>
      <p class="mt-4 text-lg text-muted-foreground">{description}</p>
      <div class="mt-6 flex items-center gap-2 text-sm text-muted-foreground">
        <time datetime={publishedDate.toISOString()}>
          {format(publishedDate, "MMMM d, yyyy")}
        </time>
      </div>
    </div>
  </div>
</section>
