---
import { ImageFigure as ImageFigureReact } from "./ImageFigure";
import { resolvePostImage } from "@lib/postImages";
import sharp from "sharp";
import path from "node:path";

interface Props {
  src: string;
  alt: string;
  caption?: string;
  className?: string;
  /** Override the detected aspect ratio, e.g. "16/9" or "4/3". */
  aspectRatio?: string;
  /** Object-fit behavior; defaults to cover. */
  fit?: "cover" | "contain";
  /** Wrapper border radius; defaults to none. */
  rounded?: "none" | "sm" | "md" | "lg" | "xl";
  /** Remove the muted placeholder background. */
  transparent?: boolean;
}

const {
  src: rawSrc,
  alt,
  caption,
  className,
  aspectRatio: authorAspectRatio,
  fit,
  rounded,
  transparent,
} = Astro.props;

// Derive the post id from the current URL so MDX images can be referenced by
// filename only. This component is only used inside post pages.
const urlSegments = Astro.url.pathname.split("/").filter(Boolean);
const postId = urlSegments[0] === "posts" ? urlSegments[1] : undefined;
const src = postId ? resolvePostImage(rawSrc, postId) : rawSrc;

// Resolve the on-disk path and read the image's aspect ratio so the figure can
// reserve the exact space without cropping or layout shift. Relative paths in
// folder-based posts are resolved to the post source folder; absolute paths are
// resolved to public/. Falls back to no ratio if the file cannot be read or if
// the author already supplied a value.
let detectedAspectRatio: string | undefined;
if (!authorAspectRatio && src) {
  const isRelative =
    !rawSrc.startsWith("/") &&
    !rawSrc.startsWith("http://") &&
    !rawSrc.startsWith("https://");
  const filePath = isRelative
    ? path.resolve("src/content/posts", postId ?? "", rawSrc)
    : path.join(process.cwd(), "public", src);
  try {
    const metadata = await sharp(filePath).metadata();
    if (metadata.width && metadata.height) {
      detectedAspectRatio = `${metadata.width} / ${metadata.height}`;
    }
  } catch {
    detectedAspectRatio = undefined;
  }
}

const aspectRatio = authorAspectRatio ?? detectedAspectRatio;
---

<ImageFigureReact
  src={src}
  alt={alt}
  caption={caption}
  className={className}
  aspectRatio={aspectRatio}
  fit={fit}
  rounded={rounded}
  transparent={transparent}
  client:load
/>
