---
import BaseLayout from "@layouts/BaseLayout.astro";
import { Container } from "@components/layout/Container";
import PostHero from "@components/blog/PostHero.astro";
import { PostList } from "@components/blog/PostList";
import { CategoryNav } from "@components/blog/CategoryNav";
import { getPublishedPosts, getFeaturedPosts } from "@lib/posts";
import { SITE } from "@data/site";

const posts = await getPublishedPosts();
const featuredPosts = await getFeaturedPosts(1);
const featuredPost = featuredPosts[0] ?? posts[0];
const latestPosts = posts.slice(0, 6);
---

<BaseLayout title="Home" permalink="/">
  <section class="border-b border-border/50 bg-muted/30 py-20">
    <Container>
      <div class="mx-auto max-w-3xl text-center">
        <h1 class="text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl">
          {SITE.name}
        </h1>
        <p class="mt-4 text-lg text-muted-foreground sm:text-xl">
          {SITE.tagline}
        </p>
        <div class="mt-8 flex justify-center gap-3">
          <a
            href="/posts"
            class="inline-flex h-9 items-center justify-center gap-2 rounded-lg bg-primary px-4 py-2 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90 hover:brightness-110"
          >
            Browse posts
          </a>
          <a
            href="/rss.xml"
            class="inline-flex h-9 items-center justify-center gap-2 rounded-lg border border-input bg-background px-4 py-2 text-sm font-medium transition-colors hover:bg-accent hover:text-accent-foreground"
          >
            Subscribe via RSS
          </a>
        </div>
      </div>
    </Container>
  </section>

  {
    featuredPost && (
      <section class="py-12">
        <Container>
          <h2 class="mb-6 text-2xl font-semibold tracking-tight">
            Featured post
          </h2>
          <PostHero post={featuredPost} />
        </Container>
      </section>
    )
  }

  <section class="py-12">
    <Container>
      <div
        class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between"
      >
        <h2 class="text-2xl font-semibold tracking-tight">Categories</h2>
        <CategoryNav />
      </div>
    </Container>
  </section>

  <section class="border-t border-border/50 py-12">
    <Container>
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="mb-2 text-2xl font-semibold tracking-tight">Search</h2>
        <p class="mb-6 text-sm text-muted-foreground">
          Find posts, authors, categories, and pages across the blog.
        </p>
        <button
          type="button"
          class="group flex w-full items-center gap-3 rounded-xl border border-border/60 bg-muted px-4 py-3 text-left text-sm text-muted-foreground transition-colors hover:border-border hover:bg-accent hover:text-accent-foreground"
          onclick="window.dispatchEvent(new CustomEvent('command-palette:open'))"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="shrink-0"
          >
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.3-4.3"></path>
          </svg>
          <span class="flex-1">Search posts, authors...</span>
          <kbd
            class="hidden rounded border border-border bg-background px-1.5 py-0.5 text-xs font-sans sm:inline"
            >Ctrl K</kbd
          >
        </button>
      </div>
    </Container>
  </section>

  <section class="border-t border-border/50 py-12">
    <Container>
      <div class="mb-8 flex items-center justify-between">
        <h2 class="text-2xl font-semibold tracking-tight">Latest posts</h2>
        <a
          href="/posts"
          class="text-sm font-medium text-primary hover:underline"
        >
          View all
        </a>
      </div>
      <PostList posts={latestPosts} client:load />
    </Container>
  </section>
</BaseLayout>
