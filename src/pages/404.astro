---
import PageLayout from "@layouts/PageLayout.astro";
---

<PageLayout title="Page Not Found" permalink="/404">
  <div class="py-20 text-center">
    <h1 class="text-6xl font-bold tracking-tight text-primary">404</h1>
    <p class="mt-4 text-lg text-muted-foreground">
      The page you are looking for does not exist.
    </p>
    <a
      href="/"
      class="mt-6 inline-flex h-9 items-center justify-center rounded-lg bg-primary px-4 py-2 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90 hover:brightness-110"
    >
      Go back home
    </a>
  </div>
</PageLayout>
