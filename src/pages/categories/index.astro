---
import PageLayout from "@layouts/PageLayout.astro";
import { CategoryCard } from "@components/blog/CategoryCard";
import { CATEGORIES } from "@lib/categories";
import { getPublishedPosts } from "@lib/posts";

const posts = await getPublishedPosts();

const categories = CATEGORIES.map((category) => {
  const categoryPosts = posts
    .filter((post) => post.data.category === category.slug)
    .slice(0, 2);

  return {
    ...category,
    count: posts.filter((post) => post.data.category === category.slug).length,
    latestPosts: categoryPosts,
  };
});

const totalPosts = posts.length;
---

<PageLayout title="Categories" permalink="/categories">
  <div class="mb-10 text-center">
    <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">Categories</h1>
    <p class="mt-2 text-muted-foreground">
      Browse {CATEGORIES.length} topics across {totalPosts}
      {totalPosts === 1 ? "post" : "posts"}.
    </p>
  </div>

  <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
    {
      categories.map((category) => (
        <CategoryCard
          category={category}
          count={category.count}
          latestPosts={category.latestPosts}
          client:load
        />
      ))
    }
  </div>
</PageLayout>
