{
  "name": "nukehub-blog",
  "version": "1.0.0",
  "description": "NukeHub Blog — Astro + React Islands + Tailwind v4",
  "type": "module",
  "scripts": {
    "dev": "astro dev --host",
    "build": "astro build",
    "clean": "rm -rf .astro node_modules/.astro node_modules/.vite dist",
    "build:clean": "npm run clean && npm run build",
    "format": "prettier --write \"src/**/*.{ts,tsx,astro,css,scss,json,md,yml,yaml}\" \"*.{json,md,yml,yaml}\" \".github/**/*.{yml,yaml}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,astro,css,scss,json,md,yml,yaml}\" \"*.{json,md,yml,yaml}\" \".github/**/*.{yml,yaml}\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "astro preview --host",
    "astro": "astro"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nukehub-dev/nukehub-blog.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/nukehub-dev/nukehub-blog/issues"
  },
  "homepage": "https://github.com/nukehub-dev/nukehub-blog#readme",
  "dependencies": {
    "@astrojs/mdx": "^6.0.3",
    "@astrojs/react": "^5.0.7",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/vite": "4.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "framer-motion": "^12.40.0",
    "geist": "^1.7.2",
    "lucide-react": "^1.18.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "4.3.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "vite": "^7.3.6"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/typography": "^0.5.20",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^9.39.4",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.1.0",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^6.0.3",
    "wrangler": "^4.107.0"
  }
}
