# Public environment variables (bundled into the static site)
# Copy this file to .env and fill in values for local development.
# Production values are configured in the Cloudflare Pages dashboard.

# Optional: Cloudflare Web Analytics token
# PUBLIC_CF_ANALYTICS_TOKEN=

# NukeHub API server URL (used for newsletter signup)
# PUBLIC_API_URL=http://localhost:3000

# Cloudflare Turnstile site key for CAPTCHA-protected forms
# PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
